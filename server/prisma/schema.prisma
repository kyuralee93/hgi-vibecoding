// 해외 재보험 관리시스템 데이터 모델 (gra 최신 프로토타입 기준)
// v62 아키텍처 + gra가 추가한 컬렉션(Intake, Cession) 및 신규 필드 반영.
// 관계: Accident→Contract, InwardClaim→FacInward 를 인덱스로 연결(프로토타입의
// 자유 입력 수용을 위해 하드 FK 대신 인덱스 참조).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 기간계 수재계약 (공식 원천)
model Contract {
  policyNo     String  @id
  insured      String
  country      String
  city         String
  lat          Float?
  lng          Float?
  line         String
  industry     String?
  tsiEok       Float   @default(0)
  premiumEok   Float   @default(0)
  currency     String  @default("KRW")
  sourceType   String?
  sourceSystem String?
  renewalDate  String?
  ppwDate      String? // gra 신규
  status       String?
  lossRatio    Float?
  expenseRatio Float?
}

// 임의수재 계약
model FacInward {
  inwardRef           String  @id
  intakeNo            String? // gra 신규: 연결된 Intake 번호
  insured             String
  country             String
  city                String
  lat                 Float?
  lng                 Float?
  line                String
  industry            String?
  tsiEok              Float   @default(0)
  premiumOriginal     Float   @default(0)
  currency            String  @default("USD")
  fxRate              Float?
  premiumEok          Float   @default(0)
  cedant              String?
  slipSummary         String?
  memo                String?
  ppwDate             String?
  receivableStatus    String?
  owner               String?
  receivableOwner     String?
  receivableUpdatedAt String?
  sourceType          String?
  sourceSystem        String?
  status              String?
  reviewStatus        String? // gra 신규
  reviewOwner         String? // gra 신규
  requestSource       String? // gra 신규
  confirmNote         String? // gra 신규
  statusHistory       Json? // gra 신규: 상태변경 이력 배열
  createdAt           String? // gra 신규
}

// 기간계 사고계약 데이터
model Accident {
  claimNo            String  @id
  policyNo           String
  insured            String
  country            String?
  city               String?
  line               String?
  cause              String?
  paidLossEok        Float   @default(0)
  outstandingLossEok Float   @default(0)
  grossLossEok       Float   @default(0)
  claimDate          String?
  status             String?
  sourceType         String?
  sourceSystem       String?
  memo               String?
  uploadBatch        String?
  eventId            String? // gra 신규: Cat 이벤트 식별자
  eventName          String? // gra 신규

  @@index([policyNo])
}

// 해외수재 클레임 (gra에서 필드 대폭 확장 — 슈퍼셋으로 수용)
model InwardClaim {
  claimNo            String  @id
  inwardRef          String
  policyNo           String? // gra 신규
  insured            String
  cedant             String?
  country            String?
  city               String?
  line               String?
  cause              String?
  paidLossEok        Float   @default(0) // gra 신규
  outstandingLossEok Float   @default(0) // gra 신규
  estimatedLossEok   Float   @default(0)
  grossLossEok       Float   @default(0) // gra 신규
  claimDate          String? // gra 신규
  noticeDate         String?
  portalStatus       String? // gra 신규
  surveyStatus       String?
  surveyPdf          String?
  status             String?
  owner              String? // gra 신규
  memo               String? // gra 신규
  sourceType         String?
  updatedBy          String? // gra 신규
  updatedAt          String? // gra 신규

  @@index([inwardRef])
  @@index([policyNo])
}

// 약관·특약 문서
model Document {
  docId           String  @id
  title           String
  type            String?
  keywords        String?
  file            String?
  sourceType      String?
  treatyId        String?
  platformFeature String?
}

// 재보험 프로그램(Treaty)
model Treaty {
  treatyId    String        @id
  name        String
  type        String?
  description String?
  exclusions  String        @default("[]") // JSON 문자열 배열
  layers      TreatyLayer[]
}

model TreatyLayer {
  id       String  @id @default(cuid())
  treatyId String
  layer    String
  from     Float   @default(0)
  to       Float   @default(0)
  lead     String?
  treaty   Treaty  @relation(fields: [treatyId], references: [treatyId], onDelete: Cascade)

  @@index([treatyId])
}

// Layer 소진 현황
model LayerStatus {
  statusId           String       @id
  treatyId           String
  treatyName         String?
  layer              String
  baseLimitEok       Float        @default(0)
  paidUsedEok        Float        @default(0)
  outstandingUsedEok Float        @default(0)
  reinstatedLimitEok Float        @default(0)
  updatedBy          String?
  updatedAt          String?
  layerClaims        LayerClaim[]
}

// Layer-사고 배분 (gra에서 필드 확장)
model LayerClaim {
  id                   String      @id @default(cuid())
  statusId             String
  treatyId             String? // gra 신규
  layer                String? // gra 신규
  claimNo              String
  policyNo             String?
  insured              String?
  paidLossEok          Float       @default(0)
  outstandingLossEok   Float       @default(0)
  grossLossEok         Float       @default(0) // gra 신규
  allocPaidEok         Float       @default(0) // gra 신규
  allocOutstandingEok  Float       @default(0) // gra 신규
  allocGrossEok        Float       @default(0) // gra 신규
  note                 String?
  eventKey             String? // gra 신규
  layerStatus          LayerStatus @relation(fields: [statusId], references: [statusId], onDelete: Cascade)

  @@index([statusId])
}

// 해외계약 Intake (gra 신규 컬렉션)
model Intake {
  id              String  @id
  source          String?
  owner           String?
  insured         String?
  country         String?
  city            String?
  line            String?
  tsiEok          Float   @default(0)
  premiumOriginal Float   @default(0)
  currency        String?
  fxRate          Float?
  premiumEok      Float   @default(0)
  partner         String?
  due             String?
  stage           String?
  lossHistory     String?
  lossAmountEok   Float   @default(0)
  lossDesc        String?
  memo            String?
  rawText         String?
  createdAt       String?
  updatedAt       String?
  createdBy       String?
}

// 출재(Cession) 계약 (gra 신규 컬렉션)
model Cession {
  cessionNo             String  @id
  reinsurer             String?
  type                  String?
  originalInsured       String?
  country               String?
  city                  String?
  line                  String?
  cededTsiEok           Float   @default(0)
  cededPremiumOriginal  Float   @default(0)
  currency              String?
  cededPremiumEok       Float   @default(0)
  ppwDate               String?
  paymentStatus         String?
  inceptionDate         String?
  linkedPolicyNo        String?
  sourceType            String?
  sourceSystem          String?
}

// 환율
model FxRate {
  currency String @id
  rate     Float
}

// 앱 메타(마감일자 등 key-value)
model AppMeta {
  key   String @id
  value String
}

// 사용자 / 권한
model User {
  id           String   @id @default(cuid())
  empNo        String   @unique
  passwordHash String
  name         String?
  role         String   @default("USER") // ADMIN / GLOBAL / UW / CLAIM / USER
  approved     Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// 변경 감사 로그
model AuditLog {
  id        String   @id @default(cuid())
  entity    String
  entityId  String?
  action    String
  actor     String?
  detail    String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
}
