# 프로덕션 환경변수 — 이 파일을 .env 로 복사해서 채우세요: cp .env.prod.example .env
# (.env 는 .gitignore 됨. 절대 커밋하지 마세요.)

# ── 접속 주소 ──────────────────────────────────────────────
# 도메인이 있으면 도메인을 적으면 HTTPS가 자동 발급됩니다.
#   SITE_ADDRESS=gra.example.com
# 도메인 없이 IP로 임시 접속하려면 :80 으로 두세요(HTTP).
SITE_ADDRESS=:80

# ── 비밀값 (반드시 강한 값으로 변경) ───────────────────────
# DB 비밀번호 (영숫자 16자 이상 권장)
POSTGRES_PASSWORD=change-this-strong-db-password
# JWT 서명 키 (랜덤 32자 이상 권장: openssl rand -hex 32)
JWT_SECRET=change-this-random-jwt-secret

# ── AI (Claude) ───────────────────────────────────────────
# 새로 발급한 키를 넣으세요(이전 노출 키는 폐기). 비우면 AI 기능만 비활성.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
